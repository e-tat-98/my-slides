{
  "name": "my-slides",
  "type": "module",
  "private": true,
  "scripts": {
    "build:slides": "pnpm --filter './slides/*' --parallel build",
    "build:index": "tsx scripts/gen-index.ts",
    "build:thumbnail": "tsx scripts/gen-thumbnail.ts",
    "preview": "tsx scripts/gen-index.ts && vite preview --outDir dist --port 4173"
  },
  "dependencies": {
    "@iconify-json/logos": "^1.2.10",
    "@slidev/cli": "^52.12.0",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "slidev-theme-penguin": "^2.3.1",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "playwright-chromium": "^1.59.1",
    "tsx": "^4.21.0"
  }
}
